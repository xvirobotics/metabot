CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/VolcEngineRTC" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/BMF" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/ByteRTCVideoDenoiseExtension" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/ByteRTCVideoSRExtension" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/ByteRTCVideoSharpenExtension" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/CVByteNN" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/Core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/RTCFFmpeg" "${PODS_XCFRAMEWORKS_BUILD_DIR}/VolcEngineRTC/RealXBase"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -framework "ByteRTCVideoDenoiseExtension" -framework "ByteRTCVideoSRExtension" -framework "ByteRTCVideoSharpenExtension" -framework "RTCFFmpeg" -framework "RealXBase" -framework "VolcEngineRTC" -framework "bmf_mods_shared" -framework "bytenn"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/VolcEngineRTC"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
